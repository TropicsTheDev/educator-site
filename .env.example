# ============================================
# Educator Site — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Sanity Studio (SANITY_STUDIO_ prefix is auto-exposed to Studio client bundle) ---
# These are NOT secrets — they are visible in the browser when running Studio.
SANITY_STUDIO_PROJECT_ID=h11qkpwx
SANITY_STUDIO_DATASET=production

# --- Nuxt Frontend (Public) ---
# These map to runtimeConfig.public via NUXT_PUBLIC_ prefix.
NUXT_PUBLIC_SANITY_PROJECT_ID=h11qkpwx
NUXT_PUBLIC_SANITY_DATASET=production
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Nuxt Frontend (Server-only secrets) ---
# These map to runtimeConfig via NUXT_ prefix (without PUBLIC).
# NEVER commit real values for these.

# Sanity API read token for preview/draft mode (create at manage.sanity.io)
NUXT_SANITY_API_READ_TOKEN=

# Resend API key for contact form emails (create at resend.com)
NUXT_RESEND_API_KEY=

# ============================================
# IMPORTANT: Before production deploy
# ============================================
# 1. Add your production domain to Sanity CORS origins at manage.sanity.io
# 2. Verify your sending domain in Resend dashboard (DNS: SPF + DKIM records)
# 3. Update NUXT_PUBLIC_SITE_URL to your production URL
